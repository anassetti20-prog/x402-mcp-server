{
  "name": "x402-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for x402 Multi-Service API — 47 pay-per-use AI services on Base chain (USDC)",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "node test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.0",
    "@pyrimid/sdk": "^0.2.6"
  },
  "openclaw": {
    "extensions": ["./openclaw-entry.ts"],
    "runtimeExtensions": ["./index.js"],
    "install": {
      "git": "https://github.com/anassetti20-prog/x402-mcp-server.git",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2025.1.0",
      "minGatewayVersion": "2026.4.10"
    },
    "build": {
      "openclawVersion": "2026.5.7"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": false
    }
  }
}
